name: california-housing-mlproject

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      n_estimators:
        type: int
        default: 200
      max_depth:
        type: int
        default: 10
      learning_rate:
        type: float
        default: 0.1
      train_path:
        type: str
        default: "california_housing_preprocessing/train.csv"
      test_path:
        type: str
        default: "california_housing_preprocessing/test.csv"
    command: "python modelling.py --n_estimators {n_estimators} --max_depth {max_depth} --learning_rate {learning_rate} --train_path {train_path} --test_path {test_path}"
